{
  "name": "jspic",
  "version": "0.1.1",
  "description": "Native TypeScript implementation of PIC-like diagram language to SVG",
  "type": "module",
  "main": "./dist/jspic.umd.js",
  "module": "./dist/jspic.js",
  "types": "./dist/jspic.d.ts",
  "exports": {
    ".": {
      "types": "./dist/jspic.d.ts",
      "import": "./dist/jspic.js",
      "require": "./dist/jspic.umd.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "test": "node --import=tsx src/test.ts",
    "dev": "vite",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pragdave/jspic.git"
  },
  "keywords": [
    "diagram",
    "svg",
    "pic",
    "pikchr",
    "graphics",
    "visualization"
  ],
  "author": "Dave Thomas",
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "license": "MPL"
}
