{
  "name": "picjs",
  "version": "0.1.2",
  "description": "Native TypeScript implementation of PIC-like diagram language to SVG",
  "type": "module",
  "main": "./dist/picjs.umd.js",
  "module": "./dist/picjs.js",
  "types": "./dist/picjs.d.ts",
  "bin": {
    "picjs": "./bin/picjs"
  },
  "exports": {
    ".": {
      "types": "./dist/picjs.d.ts",
      "import": "./dist/picjs.js",
      "require": "./dist/picjs.umd.js"
    }
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "test": "node --import=tsx src/test.ts",
    "dev": "vite",
    "cli": "node --import=tsx bin/picjs",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pragdave/picjs.git"
  },
  "keywords": [
    "diagram",
    "svg",
    "pic",
    "pikchr",
    "graphics",
    "visualization"
  ],
  "author": "Dave Thomas",
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "license": "MPL"
}
